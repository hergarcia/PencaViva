# Supabase project credentials (from supabase.com/dashboard > Settings > API Keys)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# Google Sign-In (OAuth 2.0 client IDs from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Integration tests (Supabase DB direct connection)
# Option A: Remote DB (Supabase Dashboard > Settings > Database > Connection string > URI, direct NOT pooler)
# Format: postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres
# Option B: Local DB (run `npm run supabase:start` first, requires Docker)
# Format: postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_DB_URL=
# Service role key (found in Supabase Dashboard > Settings > API > service_role key)
# WARNING: Never commit the actual value to git
SUPABASE_SERVICE_ROLE_KEY=
