{
  "name": "pencaviva",
  "version": "0.0.0-development",
  "private": true,
  "main": "expo-router/entry",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest --selectProjects unit",
    "test:supabase": "jest --selectProjects supabase",
    "test:supabase:local": "SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres jest --selectProjects supabase",
    "test:ci": "jest --selectProjects unit --ci --coverage --forceExit",
    "supabase:start": "npx supabase start -x realtime,storage-api,imgproxy,edge-runtime,logflare,vector,supavisor",
    "supabase:stop": "npx supabase stop",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "expo:doctor": "npx expo-doctor",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-native-google-signin/google-signin": "16.1.2",
    "@supabase/supabase-js": "2.99.0",
    "expo": "~55.0.5",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.16",
    "expo-image-picker": "~55.0.12",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.5",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-updates": "~55.0.13",
    "nativewind": "5.0.0-preview.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-css": "3.0.4",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "use-sync-external-store": "1.6.0",
    "zustand": "5.0.11"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-css"
        ]
      }
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^20.4.3",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "^29.0.0",
    "@types/pg": "8.18.0",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "dotenv": "17.3.1",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.0.0",
    "jest": "^29.0.0",
    "jest-expo": "~55.0.9",
    "pg": "8.20.0",
    "postcss": "8.5.8",
    "prettier": "^3.0.0",
    "semantic-release": "^24.0.0",
    "supabase": "2.77.1",
    "tailwindcss": "4.2.1",
    "ts-jest": "29.4.6",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "lightningcss": "1.30.1"
  }
}
